# --- Base de données (Neon Postgres) ---
DATABASE_URL=

# --- Mode prototype (démo testable sans email) ---
# Mettre à "1" pour une démo : connexion instantanée sans email (le serveur suit le magic
# link lui-même) + bascule de rôle organisateur/bénévole dans /compte. NE PAS activer en prod.
PROTOTYPE_MODE=

# --- Épics suivants (placeholders, à activer le moment venu) ---

# Resend — envoi des magic links (Epic 2)
RESEND_API_KEY=
# EMAIL_FROM="Bénévoles ACGB <onboarding@resend.dev>"

# Better Auth (Epic 2) — secret aléatoire (ex. `openssl rand -base64 32`)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5173

# Web Push / VAPID — notifications (Epic 6)
# Générer une paire : `npx web-push generate-vapid-keys --json`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@acgb.ch
# Clé publique exposée au client (doit être identique à VAPID_PUBLIC_KEY)
PUBLIC_VAPID_KEY=

# Cron — sweep manuel de secours (GET /api/cron/reminders), plus programmé par Vercel.
# À déclencher à la main : `Authorization: Bearer $CRON_SECRET`.
CRON_SECRET=

# Upstash QStash — planification événementielle des rappels (remplace le cron).
# Dashboard Upstash > QStash. Activer le plan pay-as-you-go (délai jusqu'à 1 an ; reste
# gratuit sous 500 msg/jour). Le callback QStash cible ${BETTER_AUTH_URL}/api/qstash/reminder
# → BETTER_AUTH_URL doit être une URL HTTPS publique en prod (QStash n'atteint pas localhost).
# QSTASH_URL : endpoint régional (optionnel ; défaut = global). Copier depuis le dashboard.
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
